@startuml Hybrid Thesis Recommender - Deployment (Simplified)

skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 9
skinparam node {
    BackgroundColor #FFFFFF
    BorderColor #333333
}

' Client
node "Client" {
    [Browser] as Browser
    [TypeScript] as TS
}

' Server
node "Server\n(localhost:5000)" {
    [Flask] as Flask
    [Retrievers] as Ret
    [Ranker] as Rank
    [Verifier] as Ver
}

' Storage
node "Storage" {
    database "FAISS\n500MB" as FAISS
    database "BM25\n50MB" as BM25
    database "SQLite\n30MB" as DB
}

' External
cloud "External" {
    [DuckDuckGo] as DDG
    [Semantic\nScholar] as SS
    [arXiv] as Arxiv
}

' Connections
Browser --> TS
TS --> Flask : HTTP\nport 5000

Flask --> Ret
Ret --> Rank
Rank --> Ver

Ret --> FAISS
Ret --> BM25
Ret --> DB
Rank --> DB

Ret --> DDG
Ret --> SS
Ret --> Arxiv

note right of FAISS
  768-dim vectors
  mpnet-base-v2
end note

note right of DDG
  No API key
  Timeout: 10s
end note

@enduml
