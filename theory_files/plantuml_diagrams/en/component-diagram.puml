@startuml Hybrid Thesis Recommender - Component Diagram

!define RECTANGLE class

skinparam componentStyle rectangle
skinparam backgroundColor #FEFEFE
skinparam defaultFontSize 10
skinparam component {
    BackgroundColor<<frontend>> #E1F5FF
    BackgroundColor<<api>> #FFF4E1
    BackgroundColor<<retrieval>> #E8F5E9
    BackgroundColor<<processing>> #FFF3E0
    BackgroundColor<<storage>> #F3E5F5
    BackgroundColor<<external>> #FFE0B2
    BorderColor #333333
    ArrowColor #666666
}
skinparam nodesep 10
skinparam ranksep 20

' Frontend
package "Frontend" <<frontend>> {
    [Browser] as Browser
    [TypeScript] as TSApp
}

' API Layer
package "API" <<api>> {
    [Flask] as Flask
    [Blueprints] as BP
    [LangDetect] as LD
}

' Retrieval
package "Retrieval" <<retrieval>> {
    [Semantic] as SR
    [Keyword] as KR
    [Web] as WR
    [Academic] as AR
}

' Processing
package "Processing" <<processing>> {
    [Ranker] as HR
    [Verifier] as CV
}

' Storage
package "Storage" <<storage>> {
    database "FAISS" as FAISS
    database "BM25" as BM25
    database "SQLite" as DB
}

' External
package "External" <<external>> {
    [Web APIs] as WebAPI
    [Academic APIs] as AcadAPI
}

' Connections
Browser --> TSApp
TSApp --> Flask

Flask --> BP
Flask --> LD

BP --> SR
BP --> KR
BP --> WR
BP --> AR

SR --> HR
KR --> HR
WR --> HR
AR --> HR

HR --> CV

SR --> FAISS
KR --> BM25
SR --> DB
KR --> DB
HR --> DB

WR --> WebAPI
AR --> AcadAPI

note right of HR
  RRF Fusion
  Feedback Boost
end note

note right of CV
  Clickbait Filter
  Domain Blocklist
end note

@enduml
