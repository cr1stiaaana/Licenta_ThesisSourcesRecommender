@startuml Hybrid Thesis Recommender - Feedback Flow Sequence

skinparam backgroundColor #FEFEFE
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor User
participant "Browser\n(TypeScript)" as Browser
participant "Flask API\n(api.py)" as API
participant "Feedback\nBlueprint" as FeedbackBP
participant "Feedback\nStore" as FeedbackStore
participant "SQLite DB\n(feedback.db)" as DB

== Submit Rating ==

User -> Browser: Click star rating\n(4 stars)
activate Browser

Browser -> Browser: Update UI\n(fill stars)

Browser -> API: POST /feedback\n{item_id, query, rating: 4,\nsession_id}
activate API

API -> FeedbackBP: handle_feedback()
activate FeedbackBP

FeedbackBP -> FeedbackBP: Validate rating\n(must be 1-5)

alt Rating valid
    FeedbackBP -> FeedbackStore: upsert_rating(item_id,\nquery, rating, session_id)
    activate FeedbackStore
    
    FeedbackStore -> DB: INSERT OR REPLACE INTO ratings\nVALUES (item_id, session_id,\nquery, rating, timestamp)
    activate DB
    
    note right of DB
      Schema:
      - item_id (TEXT)
      - session_id (TEXT)
      - query (TEXT)
      - rating (INTEGER)
      - updated_at (TIMESTAMP)
      
      Primary Key: (item_id, session_id)
    end note
    
    DB --> FeedbackStore: Success
    deactivate DB
    
    FeedbackStore --> FeedbackBP: OK
    deactivate FeedbackStore
    
    FeedbackBP --> API: {message: "Rating saved."}
    deactivate FeedbackBP
    
    API --> Browser: HTTP 200 OK\n{message: "Rating saved."}
    deactivate API
    
    Browser -> Browser: Show success\nnotification
    
else Rating invalid
    FeedbackBP --> API: {error: "Invalid rating"}
    API --> Browser: HTTP 400 Bad Request
    Browser -> Browser: Show error message
end

Browser --> User: Confirm rating saved
deactivate Browser

== Fetch Aggregate Ratings ==

User -> Browser: View article details
activate Browser

Browser -> API: GET /feedback/{item_id}\n?session_id={session_id}
activate API

API -> FeedbackBP: get_feedback()
activate FeedbackBP

FeedbackBP -> FeedbackStore: get_ratings(item_id, session_id)
activate FeedbackStore

FeedbackStore -> DB: SELECT rating\nFROM ratings\nWHERE item_id = ?\nAND session_id = ?
activate DB
DB --> FeedbackStore: user_rating (or NULL)
deactivate DB

FeedbackStore -> DB: SELECT AVG(rating),\nCOUNT(*)\nFROM ratings\nWHERE item_id = ?
activate DB
DB --> FeedbackStore: (avg_rating, count)
deactivate DB

FeedbackStore -> FeedbackStore: Build FeedbackQueryResult\n{user_rating, average_rating,\nrating_count}

FeedbackStore --> FeedbackBP: FeedbackQueryResult
deactivate FeedbackStore

FeedbackBP --> API: {user_rating: 4,\naverage: 3.7,\ncount: 12}
deactivate FeedbackBP

API --> Browser: HTTP 200 OK\nJSON response
deactivate API

Browser -> Browser: Render rating display\n"★★★★☆ (12 ratings)"\n"Your rating: ★★★★☆"

Browser --> User: Display ratings
deactivate Browser

== Feedback Signal in Ranking ==

note over User, DB
  When feedback_signal_enabled = true:
  
  1. Hybrid Ranker queries FeedbackStore
     for all candidate item_ids
  
  2. For items with avg_rating >= 4.0:
     boosted_score = rrf_score + 
                     0.1 * (avg_rating - 1) / 4
  
  3. Items with high ratings get
     ranking boost (max +0.1)
  
  Example:
  - Article A: RRF=0.5, avg_rating=4.5
    → boosted = 0.5 + 0.1*(3.5/4) = 0.5875
  
  - Article B: RRF=0.6, avg_rating=3.0
    → boosted = 0.6 (no boost, below threshold)
end note

@enduml
